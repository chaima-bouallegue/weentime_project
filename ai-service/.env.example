# Public/demo mode for the AI chatbot endpoints only (/v2/chat, /v2/chat/confirm,
# /v2/voice). When true, these endpoints fall back to an anonymous context built
# from request metadata (role, userId, entrepriseId) if the Authorization header
# is missing or invalid. Backend Spring services and ToolRegistry role checks
# remain unchanged. NEVER enable in production.
CHATBOT_PUBLIC_MODE=false