# WeenTime local infrastructure defaults

# Redis is optional infrastructure. It is not an authority store.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_AI_EVENTS_CHANNEL=ai.events.generated
REDIS_DEFAULT_TTL_SECONDS=300

# AI service
BACKEND_BASE_URL=http://localhost:8322/api/v1
AI_PROVIDER_MODE=disabled
