# WeenTime local infrastructure defaults

# Redis is optional infrastructure. It is not an authority store.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_AI_EVENTS_CHANNEL=ai.events.generated
REDIS_DEFAULT_TTL_SECONDS=300

# AI service
BACKEND_BASE_URL=http://localhost:8222/api/v1
AI_PROVIDER_MODE=disabled

# App environment (development / staging / production)
APP_ENV=development

# Cookie security (false for local HTTP dev, true for HTTPS production)
APP_COOKIE_SECURE=false

# ── Security ────────────────────────────────────────────────────────
# Generate a 256-bit hex key:  openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION_MS=86400000

# Google Gemini API key (for AI features in rh-service and ai-service)
GEMINI_API_KEY=AIzaSyAUdy7t4B9H2BW-sVtNr-qKc5YvqUs4GDk

# Internal service-to-service authentication
INTERNAL_SECRET=CHANGE_ME
INTERNAL_API_KEY=CHANGE_ME
