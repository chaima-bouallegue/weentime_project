# WeenTime ML Service environment template
APP_ENV=development
PORT=8001
LOG_LEVEL=INFO

# WeenTime Spring backend (gateway)
BACKEND_URL=http://localhost:8222
BACKEND_API_PREFIX=/api/v1
# Same secret as Spring jwt.secret in presence-service application.yml.
# Used to mint service-to-service tokens when no caller token is present.
BACKEND_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
# entrepriseId stamped on the minted service token so Spring scopes the RH
# company query to this tenant. Without it /presence/company/today is empty.
SERVICE_ENTREPRISE_ID=13

# Direct DB access (optional - the service prefers HTTP via backend)
DATABASE_URL=postgresql://weentime:170502@localhost:5433/presence_db

# Model artifacts
MODEL_DIR=storage/models
TRAINING_DATA_DIR=storage/training_data
MIN_TRAINING_RECORDS=100
MIN_REAL_TRAINING_RECORDS=30
AUTO_CALIBRATE_THRESHOLDS=true

# CORS (Angular app + ai-service)
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8000

# Anomaly thresholds (model output score -> risk level)
CRITICAL_THRESHOLD=0.85
HIGH_THRESHOLD=0.70
MEDIUM_THRESHOLD=0.50
CONTAMINATION=0.05

# Braintrust (optional and failure-tolerant)
BRAINTRUST_ENABLED=false
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_ID=20c85e3f-039c-4bc1-999e-a7d38ccdce25
BRAINTRUST_PROJECT_NAME=WeenTime ML Analytics
BRAINTRUST_ENV=development
BRAINTRUST_SAMPLE_RATE=1.0
